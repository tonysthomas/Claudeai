# ─────────────────────────────────────────────
# TARA — Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit the real .env file
# ─────────────────────────────────────────────

# Server
PORT=3000

# Anthropic (one key per client workspace)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# WhatsApp Business (Meta Developer Console)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Choose any string — paste same value into Meta webhook verification field
WHATSAPP_VERIFY_TOKEN=

# Organisation (set per client workspace)
ORG_NAME=My Organisation
ORG_PRIMARY_KPI=Revenue
ORG_CURRENCY=AED
